root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true

[*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,vue,css,scss,less,html,json,jsonc,json5,yml,yaml}]
trim_trailing_whitespace = true
max_line_length = 100

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 100
