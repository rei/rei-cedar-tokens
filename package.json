{
  "name": "@rei/cdr-tokens",
  "version": "14.0.0",
  "type": "module",
  "description": "Tokens for REI cedar design system",
  "author": "REI Software Engineering",
  "homepage": "https://rei.github.io/rei-cedar-tokens/#/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rei/rei-cedar-tokens.git"
  },
  "license": "ISC",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/rei-dot-com/js/cdr-tokens.cjs",
  "module": "./dist/rei-dot-com/js/cdr-tokens.mjs",
  "types": "./dist/rei-dot-com/js/cdr-tokens.d.mts",
  "exports": {
    ".": {
      "types": "./dist/rei-dot-com/js/cdr-tokens.d.mts",
      "import": "./dist/rei-dot-com/js/cdr-tokens.mjs",
      "require": "./dist/rei-dot-com/js/cdr-tokens.cjs"
    },
    "./docsite": {
      "types": "./dist/docsite/js/cdr-tokens.d.mts",
      "import": "./dist/docsite/js/cdr-tokens.mjs",
      "require": "./dist/docsite/js/cdr-tokens.cjs"
    },
    "./dist/": "./dist/"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "prerelease": "cross-env NODE_ENV=prerelease npm-publish-prerelease",
    "build:tokens": "pnpm run clean && tsx ./style-dictionary/build.ts",
    "clean": "rimraf dist/",
    "build": "pnpm run clean && pnpm run build:tokens && pnpm run site-tokens && pnpm run validate",
    "build:grid": "tsx grid.ts",
    "site-tokens": "tsx ./site-tokens.ts",
    "lint-staged": "lint-staged",
    "format": "oxlint --fix && oxfmt",
    "validate": "tsx ./validate.ts",
    "validate:update": "tsx ./validate.ts --update",
    "tokens:update": "tsx ./tokens-studio/token-updater.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@divriots/style-dictionary-to-figma": "^0.4.0",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/html": "^8.6.17",
    "@storybook/html-vite": "^8.6.17",
    "@tokens-studio/sd-transforms": "^1.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.21",
    "@vitest/ui": "^4.0.16",
    "commitizen": "^4.3.1",
    "concat": "^1.0.3",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "dir-to-json": "^1.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lodash": "^4.17.21",
    "npm-publish-prerelease": "^1.0.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "query-string": "^9.1.0",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.17",
    "style-dictionary": "^4.0.1",
    "tinycolor2": "^1.6.0",
    "tsx": "^4.19.2",
    "vitest": "^4.0.16"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.mjs": "npm run format"
  },
  "engines": {
    "node": ">= 22.0.0",
    "pnpm": ">= 10.0.0"
  }
}
